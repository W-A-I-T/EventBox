{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EventBox",
  "version": "0.3.39",
  "identifier": "app.danceflowcontrol.eventbox",
  "build": {
    "frontendDist": "../src",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "EventBox",
        "width": 640,
        "height": 520,
        "resizable": true,
        "minWidth": 480,
        "minHeight": 400,
        "center": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all",
    "createUpdaterArtifacts": "v1Compatible",
    "windows": {
      "wix": {
        "language": "en-US"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "resources": [
      "resources/eventbox-server*",
      "resources/server.ts"
    ],
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1"
        ],
        "section": "utils",
        "priority": "optional"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM3NEQ5RTdCNzk4MUVCODEKUldTQjY0RjVlNTVOeDZoaUt6UzhBc1dFQjkzM3hxTkd3YUtWUzFIeFZtRlh3QldKaDVsUlVRYWsK",
      "endpoints": [
        "https://github.com/W-A-I-T/EventBox/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
